# Preferred Equity Analysis Swarm: Environment Configuration
# Copy this file to .env and fill in your API keys.

# Google Gemini API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Gemini Model Name (optional, defaults to gemini-2.5-flash)
# Available models: gemini-2.5-flash, gemini-2.5-pro, gemini-2.0-flash
# Preview models: gemini-3-flash, gemini-3.1-flash-lite
# GEMINI_MODEL=gemini-2.5-flash

# FRED API Key (optional, for precise Treasury yield data)
# Get yours at: https://fred.stlouisfed.org/docs/api/api_key.html
# If not set, the app will use local rate snapshots as a fallback.
# FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage API Key (required for live market-data integration)
# Get yours at: https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Optional: path to Alpha Vantage's official listing_status.csv file
# This lets the app resolve official Alpha symbols like ALL-P-H directly.
# ALPHA_VANTAGE_LISTING_STATUS_PATH=/absolute/path/to/listing_status.csv

# Market data provider (optional)
# Alpha Vantage is now the sole supported live market-data provider.
# MARKET_DATA_PROVIDER=alpha_vantage

# SEC EDGAR User Agent (optional)
# SEC requires a user agent string for API access.
# SEC_USER_AGENT=YourName your_email@example.com
